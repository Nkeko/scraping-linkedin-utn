LINKEDIN_EMAIL=tu_email@ejemplo.com
LINKEDIN_PASSWORD=tu_password
LINKEDIN_SCHOOL_ID=      # Se descubre automaticamente al correr el script (dejar vacio)
HEADLESS=false
OUTPUT_FILE=output/utn_ba_mecanica.csv

# OPCION RECOMENDADA: usar cookie li_at del navegador (evita CAPTCHA y verificaciones)
# Como obtenerla:
# 1. Abrí LinkedIn en Chrome/Edge en Windows y logueate normalmente
# 2. F12 -> Application -> Cookies -> https://www.linkedin.com
# 3. Copiá el valor del cookie "li_at" y pegalo abajo
LINKEDIN_COOKIE_LI_AT=
